{
    "code": "salat_khodoaa_llab",
    "title": "صلاة خضوع للاب",
    "style": 1,
    "content": [
        {
            "speaker": "الشعب",
            "text_ar": [
                "بالمسيح يسوع ربنا ."
            ],
            "text_ar_co": [
                "خين بخريستوس ايسوس بين تشويس  ."
            ],
            "text_co": []
        },
        {
            "speaker": "الشماس",
            "text_ar": [
                "أحنوا رؤوسكم للــــــــــــرب"
            ],
            "text_ar_co": [
                "طاس كيفالاس إيمون طو كيريو إكليناتي"
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "أمامك يا رب"
            ],
            "text_ar_co": [
                "إينوبيون سو كيريي"
            ],
            "text_co": []
        },
        {
            "speaker": "الشماس",
            "text_ar": [
                "ننصت بخوف الله آمــــــــــــــين"
            ],
            "text_ar_co": [
                "إبروس خومين ثيئوميطافوفو آمين"
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "السلام للكل"
            ],
            "text_ar_co": [
                "إيريني باسى"
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "و لروحِك (أيضًا)"
            ],
            "text_ar_co": [
                "كيطو إبنيفما تى سو"
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "أذكر يا رب اجتماعاتنا باركها"
            ],
            "text_ar_co": [
                "آري إفميفئي إبشويس إن نين جينثؤوتي إزمو إيرؤو"
            ],
            "text_co": []
        },
        {
            "speaker": "الشماس",
            "text_ar": [
                "خلصت حقاً ومع روحك أيضا ننصت بخوف الله"
            ],
            "text_ar_co": [
                "سوتيس آمين كيطو إبنيفماتي سو ميتا فوفو ثيؤ بروس خومين"
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "آمين يا ربُّ ارحَمْ  (3)"
            ],
            "text_ar_co": [
                "آمين كيريي إليسون (3)"
            ],
            "text_co": []
        }
    ]
}