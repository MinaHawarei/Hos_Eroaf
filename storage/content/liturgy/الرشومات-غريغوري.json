{
    "code": "alrshomat",
    "title": "الرشومات",
    "style": 1,
    "content": [
        {
            "speaker": "الشعب",
            "text_ar": [
                "كرحمتك يا رب وليس كخطايانا"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "أقدم لك يا سيدي مشورات حريتي وأكتب أعمالي تبعاً لأقوالك. أنت الذي أعطيتني هذه",
                "الخدمة المملوءة سراً. أعطيتني إصعاد جسدك بخبز وخمر."
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "نؤمن"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "لأنك في الليلة التي أسلمت فيها ذاتك بإرادتك وسلطانك وحدك.",
                "أخذت خبزاً على يديك الطاهرتين اللتين بلا عيب ولا دنس الطوباويتين المحييتين"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "نؤمن أن هذا هو بالحقيقةِ آمين"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "ونظرت إلى فوق نحو السماء إلى الله أبيك وسيد كل أحد",
                "وشــــــــكرَت"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "أميـــــــــن"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "وباركـــَـتـــه"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "أميـــــــــن"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "وقدسته"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "أميـــــــــن",
                "نؤمن ونعترف ونمجد"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "وقسمته وأعطيته لتلاميذك المكرمين القديسين ورسلك الأطهار قائلاً: خذوا كلوا منه كلكم لأن هذا هو جسدي",
                "الذي يقسم عنكم وعن كثيرين يعطي لمغفرة الخطايا هذا إصنعوه لذكري."
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "هذا هو بالحقيقةِ آميـــــــــــــن"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "هكذا أيضاً بعد أن أكلوا أخذت كأساً ومزجتها من ثمرة الكرمة و ماء",
                "وشــــــــكرت"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "أميـــــــــن"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "وباركـــَـــتـه"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "أميـــــــــن"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "وقدسته"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "أميـــــــــن",
                "و أيضا نؤمن ونعترف ونمجد"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "وذقت وأعطيتها أيضاً لتلاميذك المكرمين القديسين ورسلك الأطهار قائلاً : خذوا إشربوا منها كلكم لأن هذا هو دمي الذي للعهد الجديد الذي يسفك عنكم وعن كثيرين يعطي لمغفرة الخطايا هذا إصنعوه لذكري"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "هذا هو أيضًا بالحقيقة آمين"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "لأن كل مرة تأكلون من هذا الخبز، وتشربون من هذه الكأس تبشرون بموتي، وتعترفون بقيامتي، وتذكروني إلى أن آجئ"
            ],
            "text_ar_co": [
                null
            ],
            "text_co": []
        }
    ]
}
