{
    "code": "kean_evran",
    "title": "رشومات الحمل",
    "style": 1,
    "content": [
        {
            "speaker": "الكاهن",
            "text_ar": [
                "باسم الآب والابن",
                "والروح القدس إله واحد",
                "مبارك الله الآب ضابط",
                "الكل آمين"
            ],
            "text_ar_co": [
                "خين إفران إم إفيوت نيم إبشيرى نيم",
                "بى إبنيفما إثؤواب أونوتى إن",
                "أوأوت إف إزماروؤوت إنجى",
                "إفنوتى إفيوت بي بانطوكرارطور آمين."
            ],
            "text_co": [
                null
            ]
        },
        {
            "speaker": "الشماس",
            "text_ar": [
                "امين"
            ],
            "text_ar_co": [
                "امين"
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "مبارك إبنه الوحيد يسوع المسيح ربنا آمين"
            ],
            "text_ar_co": [
                "إف إزماروؤت إنجى بيف مونوجينيس إنشيرى إيسوس بى إخرستوس بين شويس آمين."
            ],
            "text_co": []
        },
        {
            "speaker": "الشماس",
            "text_ar": [
                "امين"
            ],
            "text_ar_co": [
                "امين"
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "مبارك الروح القدس المعزي آمين"
            ],
            "text_ar_co": [
                "إف إزماروؤت إنجى بي إبنيفما إثؤواب إمباراكليتون. آمين."
            ],
            "text_co": [
                null
            ]
        }
    ]
}