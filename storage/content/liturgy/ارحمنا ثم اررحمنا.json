{
    "code": "erhamna_thoma_erhamna",
    "title": "ارحمنا ثم اررحمنا",
    "style": 1,
    "content": [
        {
            "speaker": "الكاهن",
            "text_ar": [
                "شعبُكَ وكنيستكَ يطلبونَ إليكَ وبكَ إلى الآب معكَ قائلين :",
                "إرحمنا 3 يا الله الآب ضابط الكل",
                "إرحمنا 3 يا الله مخلصنا",
                "إرحمنا 3 يا الله ثم إرحمنا",
                "يا ربُّ ارحَمْ"
            ],
            "text_ar_co": [
                "بيـك لاؤس غار نيم تيك إككليسيا سي تيهو إيروك أووه إيڤول هيتوتك إى إفيوت نيماك إڤجو إمموس :",
                "چي ناي نان)3 إفنوتي إفيوت بي باندوكراطور",
                "(چي ناي نان)3 إفنوتي بين صوتير",
                "(چي ناي نان)3 إفنوتي أووه ناى نان",
                "كيرى ليسون"
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "إرحمنا 3 يا الله الآب ضابط الكل",
                "إرحمنا 3 يا الله مخلصنا",
                "إرحمنا 3 يا الله ثم إرحمنا",
                "يا ربُّ ارحَمْ"
            ],
            "text_ar_co": [
                "(إيليسون)3 إيماس أوثيئوس أوباتير أوباندوكراطور",
                "(إيليسون)3 إيماس أوثيئوس  أوصوتير إيمون",
                "(إيليسون)3 إيماس أوثيئوس كى إيليسون إيماس",
                "كيرى ليسون"
            ],
            "text_co": []
        }
    ]
}
