{
    "code": "magdan_w_ekraman",
    "title": "مجداً و اكراما",
    "style": 1,
    "content": [
        {
            "speaker": "الكاهن",
            "text_ar": [
                "مجدًا وإكرامًا",
                "إكرامًا ومجدًا للثالوث",
                "الأقدس الآب والإبن",
                "والروح القدس سلامًا",
                "وبنيانًا لكنيسة الله الواحدة",
                "الوحيدة المقدسة الجامعة الرسولية آمين",
                "أذكر يا رب الذين",
                "قدموا لك هذه القرابين",
                "والذين قدمت عنهم",
                "والذين قدمت بواسطتهم",
                "اعطهم كلهم الجر",
                "السمائي"
            ],
            "text_ar_co": [
                "أوأو أو نيم أو طايو أوطايو نيم",
                "أوأو أو إنتى بان آجيا إترياس",
                "إفيوت نيم إبشيرى نيم بى إبنيفما",
                "إثؤواب أو هيرينى نيم او كوت إيجين",
                "تى اوى إممافاتس إثؤواب",
                "إن كاثوليكى إن أبوسطوليكى إن إككليسيا إنتى إفنوتى آمين.",
                "آرى إفميفئى إبشويس إن نى إيطاف",
                "إينى ناك إيخون إن ناى ذورون. نيم",
                "نى إيطاف إينو إيجوؤو نيم نى إيطاف",
                "إينو إيفول هيطوطو. موى نؤو",
                "تيرو إمبى فيكى بى إيفول خين",
                "نى فيئوى."
            ],
            "text_co": [
                "Ou`wou nem outai`o@ outai`o nem",
                "ou`wou@ `n]pan`agi`a `triac",
                "Viwt nem `pSyri nem pi`Pneuma",
                "e;ouab. Ouhiryny nem oukw] `ejen",
                "ou`i `mmauatc `=e=;=u",
                "nka;oliky `n`apoctoliky `nek`klycia `nte V]@ `amyn."
            ]
        },
        {
            "speaker": "الشماس",
            "text_ar": [
                "صلوا من أجل هذه القرابين المقدسة الكريمة وتقدماتنا والذين قدموها.",
                "يا رب ارحم."
            ],
            "text_ar_co": [],
