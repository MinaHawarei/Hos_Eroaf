{
    "code": "intro_qisma",
    "title": "مقدمة القسمة",
    "style": 1,
    "content": [
        {
            "speaker": "الكاهن",
            "text_ar": [
                "وأيضاً فلنشكر الله ضابط الكل ابا ربناوإلهنا ومخلصنا يسوع المسيح لأنه جعلنا أهلاً الأن أن نقف في هذا الموضع المقدس ونرفع أيدينا إلي فوق",
                "ونخدم إسمه العظيم القدوس هو أيضاً فلنسألــــــه أن يجعلنـــــــــــا مستحقيــــــن لشركه وصعود أسراره الإلهية غــــير المائتة"
            ],
            "text_ar_co": [
                "بالين أون مارين شيبئهموت إنططق إم إفنوتي بي با نطوكراطور إفيوت إم بين شويس أووه بيننوتي أووه بين سوتير إيسوس بي إخرستوس جي آفثرين إيرإبئمبشا أو تينو إي أوهي إيراتين خين باي ما إثؤواب فاي أووه إيفاي إن نين جيج",
                "إي إبشوي أووه إي شمشي إمبيف ران إثؤواب إنثوف أون مارين تيهو إيروف هوبوس إنتيف آيتين إنئيمئبشا إنتي ميت إشقير نيم تي ميت آليمي بسيس إنتي نيف ميستيريون إن نوتي أووه إن آثمو."
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "امين"
            ],
            "text_ar_co": [
                "امين"
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "الجسد المقدس"
            ],
            "text_ar_co": [
                "بي سوما إثؤواب"
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "نسجد لجسدك المقدس"
            ],
            "text_ar_co": [
                "تين أوأوشت إمبيك سوما إثؤواب"
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "والدم الكريم"
            ],
            "text_ar_co": [
                "نيم بي إسنوف إتطايوت"
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "ولدمك الكريم"
            ],
            "text_ar_co": [
                "نيم بيك إسنوف إتطايوت"
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "اللذان لمسيحه الضابط الكل الرب إلهنا"
            ],
            "text_ar_co": [
                "إنتي بيف إخرستوس إنجي بي بانطوكراطور إبشويس بيننوتي"
            ],
            "text_co": []
        },
        {
            "speaker": "الشماس",
            "text_ar": [
                "آمين آمين صلوا"
            ],
            "text_ar_co": [
                "آمين آمين إبروس إفكساستي"
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "يا ربُّ ارحَمْ"
            ],
            "text_ar_co": [
                "كيريى إليسون"
            ],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "السلام للكل"
            ],
            "text_ar_co": [
                "إيريني باسى"
            ],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "ولروحِك (أيضًا)"
            ],
            "text_ar_co": [
                "كيطو إبنيفما تى سو"
            ],
            "text_co": []
        }
    ]
}
