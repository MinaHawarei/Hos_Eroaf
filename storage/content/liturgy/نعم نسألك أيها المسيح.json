            "text_ar_co": [],
            "text_co": []
        },
         {
            "speaker": "الشعب",
            "text_ar": [
                "يا ربُّ ارحَمْ"
            ],
            "text_ar_co": [],
            "text_co": []
        },
        {
           "speaker": "الكاهن",
            "text_ar": [
                "طهارة للذين في البتولية حياة صالحة للمتزوجين"
