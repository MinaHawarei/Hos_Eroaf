{
    "code": "naam_nasallak",
    "title": "نعم نسألك أيها المسيح",
    "style": 1,
    "content": [
        {
            "speaker": "الكاهن",
            "text_ar": [
                "نعم نسألك أيها المسيح إلهنا ثبت أساس الكنيسة"
            ],
            "text_ar_co": [],
            "text_co": []
        },
        {
            "speaker": "الشعب",
            "text_ar": [
                "يا ربُّ ارحَمْ"
            ],
            "text_ar_co": [],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "وحدانية القلب التي للمحبة فلتتأصل فينا"
            ],
            "text_ar_co": [],
            "text_co": []
        },
         {
            "speaker": "الشعب",
            "text_ar": [
                "يا ربُّ ارحَمْ"
            ],
            "text_ar_co": [],
            "text_co": []
        },
        {
            "speaker": "الكاهن",
            "text_ar": [
                "لينم بر الإيمان سهل لنا طريق التقوي"
            ],
            "text_ar_co": [],
            "text_co": []
        },
         {
            "speaker": "الشعب",
            "text_ar": [
